# Configure both values to use Supabase for meeting management data.
# Leave them unset to use the local backend/data/diting.db SQLite store.
# Keep this key on the backend only. For cloud deployment, use a server-side
# service-role key and replace the development-open RLS policies before launch.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-server-side-supabase-key

# Change the initial administrator password before first startup.
DITING_ADMIN_PASSWORD=change-me

# ── Local ASR runtime ──
# Per-recognizer CPU thread count for X-ASR and Qwen preprocessing.
# This is separate from concurrent upload jobs; keep processing workers low to
# avoid loading multiple large recordings or GPU inference jobs at once.
DITING_ASR_THREADS=12
DITING_PROCESSING_WORKERS=2

# ── LLM summary generation (OpenAI-compatible API) ──
# The settings UI overrides these values per user. These defaults use DSv4 Flash.
# DSv4 Pro model id: deepseek-v4-pro
DITING_LLM_PROVIDER=deepseek
DITING_LLM_BASE_URL=https://api.deepseek.com
DITING_LLM_API_KEY=
DITING_LLM_MODEL=deepseek-v4-flash
# Optional stable deployment secret. If omitted, a local Fernet key is generated
# once at backend/data/llm_secret.key (ignored by git).
# DITING_LLM_ENCRYPTION_KEY=replace-with-a-long-random-secret
# Optional tuning — defaults are shown.
# DITING_LLM_TIMEOUT_SEC=120
# DITING_LLM_MAX_RETRIES=3
# DITING_LLM_MAX_CONCURRENCY=2
# DITING_SUMMARY_MAX_RECORDS=20
# DITING_SUMMARY_MAX_TOTAL_CHARS=500000
